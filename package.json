{
  "name": "ai-course-designer",
  "version": "4.3.3",
  "description": "驭课 Agent v4.3.3 — 8 阶段工作流（schedule → design → ppt → lecture → quiz → homework → video → report）+ 在线测验/课后作业 AI 生成 + 跨版本数据找回 + 教师日志（前称我的工作台）",
  "main": "src/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "vite build && electron-builder",
    "preview": "vite preview",
    "pack": "electron-builder --dir",
    "dist": "vite build && electron-builder",
    "start": "electron .",
    "smoke": "node scripts/smoke-test-real-ark.js",
    "verify:contracts": "node scripts/verify-contracts-v8.js",
    "verify:integration": "node scripts/verify-workflow-integration-v8.js",
    "verify:migrations": "node scripts/verify-migrations-runner-v8.js",
    "verify:e2e:mock": "node scripts/e2e/run-e2e-v8.js --dry-run --out-dir=./scripts/e2e/.test-out --lessons=1",
    "verify:gate": "node scripts/verify-contracts-v8.js && node scripts/verify-workflow-integration-v8.js && node scripts/verify-migrations-runner-v8.js",
    "verify:all": "node scripts/verify-contracts-v8.js && node scripts/verify-workflow-integration-v8.js && node scripts/verify-migrations-runner-v8.js && echo \"OK: A 类发布门禁全过\"",
    "verify:release": "node scripts/verify-contracts-v8.js && node scripts/verify-workflow-integration-v8.js && node scripts/verify-migrations-runner-v8.js && vite build && electron-builder"
  },
  "keywords": [
    "electron",
    "react",
    "ai",
    "education",
    "course-design"
  ],
  "author": "Baggio & Claude",
  "license": "Private",
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1",
    "sharp": "^0.34.5",
    "vite": "^5.0.10"
  },
  "dependencies": {
    "antd": "^5.12.8",
    "archiver": "^6.0.1",
    "axios": "^1.6.5",
    "defuddle": "^0.18.1",
    "docx": "^8.5.0",
    "file-type": "^18.7.0",
    "lucide-react": "^0.309.0",
    "mammoth": "^1.6.0",
    "pdf-parse": "^2.4.5",
    "pptxgenjs": "^3.12.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.1",
    "turndown": "^7.2.4"
  },
  "build": {
    "appId": "com.newvision.course-designer",
    "productName": "驭课 Agent v4.3.3",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/main/**/*",
      "src/preload/**/*",
      "src/shared/**/*",
      "resources/**/*",
      "prompts/**/*",
      "skills/**/*",
      "dist/renderer/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "驭课 Agent v4.3.3"
    },
    "artifactName": "驭课Agent-v4.3.3-setup.exe"
  }
}
