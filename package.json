{
  "name": "ai-course-designer",
  "version": "1.5.0",
  "description": "刘老师课程助手 v2版 - 职业教育课程开发 Workflow Agent",
  "main": "src/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "vite build && electron-builder",
    "preview": "vite preview",
    "pack": "electron-builder --dir",
    "dist": "vite build && electron-builder",
    "start": "electron ."
  },
  "keywords": [
    "electron",
    "react",
    "ai",
    "education",
    "course-design"
  ],
  "author": "Baggio & Claude",
  "license": "Private",
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1",
    "vite": "^5.0.10"
  },
  "dependencies": {
    "antd": "^5.12.8",
    "archiver": "^6.0.1",
    "axios": "^1.6.5",
    "docx": "^8.5.0",
    "file-type": "^18.7.0",
    "lucide-react": "^0.309.0",
    "mammoth": "^1.6.0",
    "pptxgenjs": "^3.12.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.1"
  },
  "build": {
    "appId": "com.newvision.course-designer",
    "productName": "刘老师课程助手v2版",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/main/**/*",
      "src/preload/**/*",
      "src/shared/**/*",
      "resources/**/*",
      "prompts/**/*",
      "skills/**/*",
      "dist/renderer/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icons/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "刘老师课程助手v2版"
    },
    "artifactName": "刘老师课程助手v2版-setup.exe"
  }
}
